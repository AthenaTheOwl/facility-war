{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/facility-war/scenario.schema.json",
  "type": "object",
  "required": [
    "scenario_id",
    "name",
    "trigger",
    "duration_weeks_distribution",
    "affected_geographies",
    "affected_components",
    "severity_distribution",
    "references"
  ],
  "additionalProperties": true,
  "properties": {
    "scenario_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "string",
      "minLength": 1
    },
    "horizon_weeks": {
      "type": "integer",
      "minimum": 1
    },
    "duration_weeks_distribution": {
      "$ref": "#/$defs/distribution"
    },
    "affected_geographies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_components": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity_distribution": {
      "$ref": "#/$defs/distribution"
    },
    "substitution_severity_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "distribution": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "fixed"
            },
            "value": {
              "type": "number"
            }
          },
          "required": ["type", "value"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": {
              "const": "fixed_weeks"
            },
            "weeks": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": ["type", "weeks"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": {
              "const": "triangular"
            },
            "low": {
              "type": "number"
            },
            "mode": {
              "type": "number"
            },
            "high": {
              "type": "number"
            }
          },
          "required": ["type", "low", "mode", "high"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": {
              "const": "choice"
            },
            "choices": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["value"],
                "additionalProperties": false,
                "properties": {
                  "value": {
                    "type": "number"
                  },
                  "weight": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                }
              }
            }
          },
          "required": ["type", "choices"],
          "additionalProperties": false
        }
      ]
    }
  }
}
