{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/facility-war/supply_graph.schema.json",
  "type": "object",
  "required": ["graph_id", "name", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "name"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "type": {
            "type": "string",
            "enum": ["supplier", "component", "bom_item", "geography"]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "country": {
            "type": "string"
          },
          "region": {
            "type": "string"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["supplies", "located_in", "depends_on", "substitutes_for"]
          },
          "criticality": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "max_substitutable_severity": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "post_substitution_risk": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
